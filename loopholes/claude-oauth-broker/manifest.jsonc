// yolo-jail loophole manifest. See src/loopholes.py for the schema.
// Installed to ~/.local/share/yolo-jail/loopholes/claude-oauth-broker/
// by `just deploy`. The CA/leaf pair alongside is generated by
// `yolo-claude-oauth-broker-host --init-ca`, which `just deploy` runs
// once on install.
{
  "name": "claude-oauth-broker",
  "description": "Serializes Claude OAuth refreshes so multi-jail setups don't burn the single-use refresh token. TLS termination lives in each jail; a single host-side daemon owns the flock + shared credentials file.",
  "version": 1,
  "enabled": true,
  "transport": "tls-intercept",
  "lifecycle": "spawned",
  // Jails route platform.claude.com to the local daemon in the jail
  // namespace.  Binding port 443 inside the container namespace is
  // unrestricted, so no privileged-host-port gymnastics.
  "intercepts": [
    {"host": "platform.claude.com"}
  ],
  "broker_ip": "127.0.0.1",
  "ca_cert": "ca.crt",
  // Host-side: spawned per-jail by yolo's loophole pipeline.  Owns the
  // flock and the shared creds file; no network interface binding.
  "host_daemon": {
    "cmd": ["yolo-claude-oauth-broker-host", "--socket", "{socket}"]
  },
  // Jail-side: supervised by src/jail_daemon_supervisor.py at jail boot.
  // Terminates TLS for platform.claude.com in the jail namespace and
  // forwards OAuth refreshes to the host daemon over its Unix socket.
  "jail_daemon": {
    "cmd": [
      "python3", "-m", "src.oauth_broker_jail"
    ],
    "restart": "on-failure"
  },
  "doctor_cmd": ["yolo-claude-oauth-broker-host", "--self-check"]
}
